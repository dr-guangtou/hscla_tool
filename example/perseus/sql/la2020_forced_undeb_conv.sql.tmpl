  t.y_undeblended_convolvedflux_3_20_flag,
  t.y_undeblended_convolvedflux_3_20_flux,
  t.y_undeblended_convolvedflux_3_20_fluxerr,
  t.z_undeblended_convolvedflux_2_20_flag,
  t.z_undeblended_convolvedflux_2_20_flux,
