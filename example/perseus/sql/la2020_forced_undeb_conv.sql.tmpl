SELECT
  t.object_id,
  t.g_undeblended_convolvedflux_2_20_flag,
  t.g_undeblended_convolvedflux_2_20_flux,
  t.g_undeblended_convolvedflux_2_20_fluxerr,
  t.g_undeblended_convolvedflux_3_20_flag,
  t.g_undeblended_convolvedflux_3_20_flux,
  t.g_undeblended_convolvedflux_3_20_fluxerr,
  t.i_undeblended_convolvedflux_2_20_flag,
  t.i_undeblended_convolvedflux_2_20_flux,
  t.i_undeblended_convolvedflux_2_20_fluxerr,
  t.i_undeblended_convolvedflux_3_20_flag,
  t.i_undeblended_convolvedflux_3_20_flux,
  t.i_undeblended_convolvedflux_3_20_fluxerr,
  t.r_undeblended_convolvedflux_2_20_flag,
  t.r_undeblended_convolvedflux_2_20_flux,
  t.r_undeblended_convolvedflux_2_20_fluxerr,
  t.r_undeblended_convolvedflux_3_20_flag,
  t.r_undeblended_convolvedflux_3_20_flux,
  t.r_undeblended_convolvedflux_3_20_fluxerr,
  t.y_undeblended_convolvedflux_2_20_flag,
